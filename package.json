{
  "name": "tabkeep",
  "displayName": "Tabkeep",
  "version": "1.0.0",
  "description": "Tab Management Extension",
  "author": "User",
  "scripts": {
    "dev": "plasmo dev --target=firefox-mv2",
    "build": "plasmo build --target=firefox-mv2",
    "package": "plasmo package --target=firefox-mv2"
  },
  "dependencies": {
    "lucide-react": "^0.471.0",
    "plasmo": "0.89.4",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.35",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "menus",
      "tabs",
      "contextMenus",
      "unlimitedStorage"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "tabkeep-dev@yourdomain.com",
        "strict_min_version": "109.0"
      }
    }
  }
}